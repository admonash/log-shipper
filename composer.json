{
    "name": "admon/log-shipper",
    "description": "Zero-config log shipping to a centralized log server for Laravel projects",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.0",
        "illuminate/console": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Admon\\LogShipper\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Admon\\LogShipper\\LogShipperServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
